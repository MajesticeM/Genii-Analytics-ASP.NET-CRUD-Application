@model IEnumerable<Genii_Assessment.Models.Product>

@{
    ViewBag.Title = "Products";
}

<h2>Products</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (Request.IsAuthenticated)
{
    <p>
        @Html.ActionLink("Create New Product", "Create", null, new { @class = "btn btn-primary" })
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Cost Per Item</th>
            <th>Quantity In Stock</th>
            <th>Restock Threshold</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.CostPerItem.ToString("C")</td>
                <td>@product.QuantityInStock</td>
                <td>@product.RestockThreshold</td>
                <td>@(product.IsActive ? "Active" : "Inactive")</td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = product.Id }, new { @class = "btn btn-sm btn-info" })
                    @Html.Raw(" ")
                    @Html.ActionLink("Edit", "Edit", new { id = product.Id }, new { @class = "btn btn-sm btn-warning" })
                    @Html.Raw(" ")
                    @Html.ActionLink("Delete", "Delete", new { id = product.Id }, new { @class = "btn btn-sm btn-danger" })
                </td>
            </tr>
        }
    </tbody>
</table>