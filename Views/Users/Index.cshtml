@model IEnumerable<Genii_Assessment.ViewModels.UserListItemViewModel>

@{
    ViewBag.Title = "Users";
}

<h2>Users</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    @Html.ActionLink("Create New User", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Active</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.RoleName</td>
                <td>@(user.IsActive ? "Yes" : "No")</td>
                <td>@user.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = user.Id }, new { @class = "btn btn-sm btn-warning" })
                </td>
            </tr>
        }
    </tbody>
</table>