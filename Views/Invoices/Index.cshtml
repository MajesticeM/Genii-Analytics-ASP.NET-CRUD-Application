@model IEnumerable<Genii_Assessment.ViewModels.InvoiceListItemViewModel>

@{
    ViewBag.Title = "Invoices";
}

<h2>Invoices</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    @Html.ActionLink("Create New Invoice", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Invoice Date</th>
            <th>Items</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var invoice in Model)
        {
            <tr>
                <td>@invoice.InvoiceDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@invoice.ItemCount</td>
                <td>@invoice.TotalAmount.ToString("C")</td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = invoice.Id }, new { @class = "btn btn-info btn-sm" })
                    @Html.Raw(" ")
                    @Html.ActionLink("Edit", "Edit", new { id = invoice.Id }, new { @class = "btn btn-warning btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>