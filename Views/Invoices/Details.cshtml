@model Genii_Assessment.Models.Invoice

@{
    ViewBag.Title = "Invoice Details";
}

<h2>Invoice Details</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>Invoice Date</dt>
        <dd>@Model.InvoiceDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>

        <dt>Total Amount</dt>
        <dd>@Model.TotalAmount.ToString("C")</dd>
    </dl>
</div>

<h4>Items</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Product</th>
            <th>Quantity</th>
            <th>Unit Cost</th>
            <th>Line Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.InvoiceItems)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>@item.Quantity</td>
                <td>@item.UnitCost.ToString("C")</td>
                <td>@item.LineTotal.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning" })
    @Html.Raw(" ")
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
</p>